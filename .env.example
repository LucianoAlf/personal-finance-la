# ============================================================
# personal-finance-la - environment reference
# ============================================================

# Browser / Vite
# Safe to expose in the frontend because only VITE_* vars are bundled.
VITE_SUPABASE_URL=https://sbnpmhmvcspwcyjhftlw.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Supabase CLI / Management API
SUPABASE_PROJECT_REF=sbnpmhmvcspwcyjhftlw
SUPABASE_ACCESS_TOKEN=your_personal_access_token
SUPABASE_DB_PASSWORD=your_database_password

# Edge Functions / server-side only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
CRON_SECRET=your_cron_secret
RESEND_API_KEY=your_resend_api_key
OPENAI_API_KEY=your_openai_api_key
UAZAPI_SERVER_URL=your_uazapi_server_url
UAZAPI_INSTANCE_TOKEN=your_uazapi_instance_token
UAZAPI_PHONE_NUMBER=your_uazapi_phone_number
UAZAPI_WEBHOOK_URL=your_uazapi_webhook_url

# Smoke test (opcional): scripts/smoke-whatsapp-group-send.ts
# SMOKE_WHATSAPP_USER_ID=uuid_da_linha_whatsapp_connections
# SMOKE_GROUP_JID=5521981278047-1555326211@g.us

# Pluggy (Open Finance) — secrets do projeto também em Supabase Edge Functions
# PLUGGY_BASE_URL=https://api.pluggy.ai
# PLUGGY_CLIENT_ID=
# PLUGGY_CLIENT_SECRET=
# Um UUID por instituição conectada (poll-pluggy-reconciliation lê todas as chaves PLUGGY_ITEM_ID_*):
# PLUGGY_ITEM_ID_NUBANK=
# PLUGGY_ITEM_ID_ITAU=
# PLUGGY_ITEM_ID_C6_BANK=
# PLUGGY_ITEM_ID_MERCADO_PAGO=
# PLUGGY_ITEM_ID_SANTANDER=
# Alternativa para scripts locais (scripts/pluggy/verify-recent-transactions.ts): lista única, vírgula ou espaço
# PLUGGY_ITEM_IDS=uuid1,uuid2
# PLUGGY_ITEM_IDS=ITAU=uuid1 NUBANK=uuid2

# Notes
# - Do not commit real secrets.
# - Keep frontend vars in .env.local for local development.
# - Keep Playwright login creds in .env.e2e.local if you need authenticated local E2E.
# - Prefer Supabase project secrets for Edge Functions.
